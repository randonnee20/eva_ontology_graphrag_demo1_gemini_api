"""rag/llm.py — 로컬 LLM 래퍼 (Lazy load, RTX 4070 GPU)"""

import logging
from pathlib import Path
from utils.config import get_config

logger = logging.getLogger(__name__)
_llm = None

# 채팅 응답용 stop 토큰 (반복 방지)
_STOP_CHAT = [
    "</s>", "Human:", "사용자:",
    "[질문]", "[답변]", "Q:", "A:",
    "위반내용 법조문",
    "1차 위반 2차 위반",
    "1.1.1.",
]

# repeat_penalty로 반복 방지 (stop 토큰보다 효과적)
_REPEAT_PENALTY = 1.3   # 1.0=없음, 1.1~1.5 권장, 높을수록 반복 억제
_REPEAT_LAST_N  = 128   # 마지막 N 토큰 기준으로 penalty 적용

# 엔티티 추출용 stop 토큰 (JSON 출력 중단 방지 - 최소화)
_STOP_EXTRACT = [
    "</s>",
    "\n\n\n",
]


def _get_llm():
    global _llm
    if _llm is None:
        from llama_cpp import Llama
        cfg = get_config()
        model_path = cfg["llm"]["model_path"]
        if not Path(model_path).exists():
            raise FileNotFoundError(f"LLM 모델 없음: {model_path}\nconfig.yaml의 llm.model_path 확인")
        logger.info(f"LLM 로딩: {model_path}")
        _llm = Llama(
            model_path=model_path,
            n_ctx=cfg["llm"].get("n_ctx", 4096),
            n_gpu_layers=cfg["llm"].get("n_gpu_layers", -1),
            verbose=False,
        )
        logger.info("LLM 로딩 완료")
    return _llm


def generate(prompt: str, max_tokens: int = None, temperature: float = None,
             mode: str = "chat") -> str:
    """
    mode: "chat"    → 채팅 응답 (반복 방지 stop 토큰 적용)
          "extract" → 엔티티 추출 (JSON 중단 방지, stop 최소화)
    """
    cfg = get_config()
    stop_tokens = _STOP_CHAT if mode == "chat" else _STOP_EXTRACT
    # 채팅은 512, 추출은 config 값 사용
    default_tokens = 512 if mode == "chat" else cfg["llm"].get("max_tokens", 1024)

    output = _get_llm()(
        prompt,
        max_tokens=max_tokens or default_tokens,
        temperature=temperature or cfg["llm"].get("temperature", 0.2),
        stop=stop_tokens,
        repeat_penalty=_REPEAT_PENALTY if mode == "chat" else 1.0,
        echo=False,
    )
    return output["choices"][0]["text"].strip()


def is_loaded() -> bool:
    return _llm is not None