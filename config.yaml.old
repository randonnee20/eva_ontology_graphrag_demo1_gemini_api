llm:
  model_path: "E:/LLModel/llama-3.2-Korean-Bllossom-3B-gguf-Q4_K_M.gguf"
  n_ctx: 4096
  n_gpu_layers: -1
  max_tokens: 1024
  temperature: 0.2

graph:
  backend: "networkx"

neo4j:
  uri: "bolt://localhost:7687"
  user: "neo4j"
  password: "password"

embedding:
  model: "jhgan/ko-sbert-nli"
  chunk_size: 500
  chunk_overlap: 50
  top_k: 5

paths:
  raw:        "data/raw"
  text:       "data/text"
  chunks:     "data/chunks"
  embeddings: "data/embeddings"
  graph_db:   "data/graph"
  ontology:   "ontology/classes.yaml"

ingestion:
  watch_interval: 2